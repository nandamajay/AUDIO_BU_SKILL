# Keep empty evidence folders (negate the evidence ignores above)
!audio_bu_skill/targets/*/evidence/ipcat/.gitkeep
!audio_bu_skill/targets/*/evidence/offline/.gitkeep

# QGenie reasoning artifacts that may embed confidential evidence content/paths —
# never commit the prompt or the raw model transcript. The validated structured
# result (qgenie_analysis.json) and reasoning_error.json also embed evidence-derived
# content and are likewise ignored below as generated per-target artifacts.
audio_bu_skill/targets/*/qgenie_task_spec.json
audio_bu_skill/targets/*/qgenie_raw_output.txt

# Onboarding before/after snapshots may embed the same confidential evidence
# content/paths (qgenie_task_spec.json, case.py citations) — never commit.
audio_bu_skill/snapshots/

# Generated per-target onboarding artifacts. These embed confidential
# schematic/datasheet-derived content (LD20 refs, part numbers, register bases,
# firmware names) surfaced by the reasoning run, so they are never committed.
# The manually reviewed & promoted case.py (tracked) and evidence/.gitkeep
# placeholders (negated above) are the only per-target files kept in git.
audio_bu_skill/targets/*/case.generated.py
audio_bu_skill/targets/*/qgenie_analysis.json
audio_bu_skill/targets/*/reasoning_error.json
audio_bu_skill/targets/*/onboarding_report.md
audio_bu_skill/targets/*/profile.json
audio_bu_skill/targets/*/similarity_report.json
audio_bu_skill/targets/*/evidence_inventory.json
__pycache__/
*.pyc
*.pyo
audio_bu_skill/experiments/ipcat_probe/artifacts/
prior_art/
