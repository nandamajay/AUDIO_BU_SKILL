{
  "input_envelope": {
    "type": "object",
    "additionalProperties": true,
    "required": ["workspace_context", "target_soc", "run_id"],
    "properties": {
      "workspace_context": {
        "type": "object",
        "required": ["workspace_root"],
        "properties": {
          "workspace_root": {"type": "string", "minLength": 1}
        }
      },
      "target_soc": {"type": "string", "minLength": 1},
      "run_id": {"type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9_.-]+$"},
      "ipcat_export_path": {"type": "string"},
      "schematic_path": {"type": "string"},
      "io_mapping_path": {"type": "string"},
      "downstream_reference_path": {"type": "string"},
      "evidence_roots": {
        "type": "object",
        "additionalProperties": {"type": "string"},
        "properties": {
          "ipcat": {"type": "string"},
          "offline_documents": {"type": "string"}
        }
      },
      "decision": {
        "type": "object",
        "properties": {
          "evidence_source": {"type": "string", "enum": ["ipcat", "offline_documents", "both", "ipcat_first"]},
          "power_model_source": {"type": "string", "minLength": 1}
        }
      }
    }
  },
  "output_envelope": {
    "type": "object",
    "additionalProperties": true,
    "required": ["resolved_evidence_sources", "evidence"],
    "properties": {
      "resolved_evidence_sources": {
        "type": "object",
        "required": ["run_id", "evidence_source", "power_model_source", "available_inputs", "ambiguities"],
        "properties": {
          "run_id": {"type": "string", "minLength": 1},
          "evidence_source": {"type": ["string", "null"]},
          "power_model_source": {"type": ["string", "null"]},
          "available_inputs": {"type": "array", "items": {"type": "string"}},
          "ambiguities": {"type": "array", "items": {"type": "string"}}
        }
      },
      "evidence": {
        "type": "object",
        "required": ["evidence_refs"],
        "properties": {
          "evidence_refs": {"type": "array", "items": {"type": "string"}}
        }
      },
      "human_review_needed": {"type": "boolean"},
      "ambiguities": {"type": "array", "items": {"type": "string"}}
    }
  }
}
